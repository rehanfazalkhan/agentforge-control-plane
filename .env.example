# Development uses deterministic contract fixtures. Production fails closed until every
# required value below is supplied through a secret manager or workload environment.
AGENTFORGE_RUNTIME_MODE=development
AWS_REGION=us-east-1

# Production model runtime. Enable model access in Bedrock before selecting a model ID.
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=1200
BEDROCK_TEMPERATURE=0.2

# Production persistence and authentication.
AGENTFORGE_RUN_STORE=dynamodb
AGENTFORGE_RUN_TABLE=agentforge-runs
AGENTFORGE_JWT_ISSUER=https://issuer.example.com
AGENTFORGE_JWT_AUDIENCE=agentforge-api
AGENTFORGE_JWT_ROLE_CLAIM=custom:role

# HTTPS endpoints should be AgentCore Gateway targets or approved internal services.
AGENTFORGE_TOOL_SERVICE_HEALTH_URL=https://gateway.example.com/tools/service-health
AGENTFORGE_TOOL_COST_FORECAST_URL=https://gateway.example.com/tools/cost-forecast
AGENTFORGE_TOOL_RUNBOOK_SEARCH_URL=https://gateway.example.com/tools/runbook-search
AGENTFORGE_TOOL_ACCESS_REVIEW_URL=https://gateway.example.com/tools/access-review
AGENTFORGE_TOOL_TIMEOUT_SECONDS=8
